{
  "inputs": [
    {
      "id": "jiraBaseUrl",
      "type": "promptString",
      "description": "URL base do Jira (ex: https://your-company.atlassian.net)"
    },
    {
      "id": "jiraApiToken",
      "type": "promptString",
      "description": "API Token do Jira (gerar em https://id.atlassian.com/manage-profile/security/api-tokens)",
      "password": true
    },
    {
      "id": "jiraUserEmail",
      "type": "promptString",
      "description": "E-mail do usuário Jira associado ao API Token"
    }
  ],
  "servers": {
    "code-navigation": {
      "type": "stdio",
      "command": "serena",
      "args": ["start-mcp-server", "--context=vscode"]
    },
    "code-search": {
      "type": "stdio",
      "command": "codebase-memory-mcp",
      "args": []
    },
    "issue-tracker": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@anthropic/atlassian-rovo-mcp"],
      "env": {
        "JIRA_BASE_URL": "${input:jiraBaseUrl}",
        "JIRA_API_TOKEN": "${input:jiraApiToken}",
        "JIRA_USER_EMAIL": "${input:jiraUserEmail}"
      }
    }
  }
}
