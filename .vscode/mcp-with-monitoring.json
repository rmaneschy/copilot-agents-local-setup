{
  "inputs": [],
  "servers": {
    "local-code-rag": {
      "command": "python",
      "args": [
        "${userHome}/local-tools/copilot-agents-local-setup/monitoring/mcp-proxy-logger.py",
        "--server", "local-code-rag",
        "--command", "${userHome}/local-tools/mcp-venv/Scripts/python.exe",
        "--args", "-m", "mcp_vector_search.mcp.server", "${userHome}/workspace"
      ],
      "env": {
        "MCP_ENABLE_FILE_WATCHING": "true",
        "EMBEDDING_MODEL": "nomic-embed-text",
        "OLLAMA_BASE_URL": "http://localhost:11434"
      }
    },
    "serena": {
      "command": "python",
      "args": [
        "${userHome}/local-tools/copilot-agents-local-setup/monitoring/mcp-proxy-logger.py",
        "--server", "serena",
        "--command", "serena",
        "--args", "start-mcp-server", "--context=vscode"
      ]
    }
  }
}
